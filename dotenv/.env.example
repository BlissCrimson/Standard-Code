# -------------------------------------------------------
# .env.example – Vorlage für Umgebungsvariablen
#
# Diese Datei darf committet werden.
# Kopiere sie zu ".env" und trage die echten Werte ein.
# Die ".env"-Datei NIEMALS committen!
# -------------------------------------------------------

# Allgemein
APP_NAME=MeineApp
APP_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000

# Debugging
DEBUG=true
LOG_LEVEL=info

# Datenbank
DB_HOST=localhost
DB_PORT=5432
DB_NAME=meine_datenbank
DB_USER=mein_user
DB_PASSWORD=

# API-Keys (niemals echte Keys hier eintragen!)
API_KEY=
API_SECRET=
THIRD_PARTY_API_URL=https://api.example.com

# Authentifizierung
JWT_SECRET=
JWT_EXPIRES_IN=7d

# E-Mail (z.B. für SMTP)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com

# Storage / Cloud
STORAGE_BUCKET=
STORAGE_REGION=eu-central-1
